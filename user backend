package com.parking.parking.controller;

import com.parking.parking.entity.ParkingLocation;
import com.parking.parking.service.ParkingLocationService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;
import java.util.Optional;

@RestController
@RequestMapping("/api/parking")
public class ParkingController {

    @Autowired
    private ParkingLocationService parkingLocationService;

    @GetMapping("/locations")
    public ResponseEntity<List<ParkingLocation>> getAllLocations() {
        List<ParkingLocation> locations = parkingLocationService.getAllLocations();
        return ResponseEntity.ok(locations);
    }

    @GetMapping("/locations/{id}")
    public ResponseEntity<ParkingLocation> getLocationById(@PathVariable Long id) {
        Optional<ParkingLocation> location = parkingLocationService.getLocationById(id);
        return location.map(ResponseEntity::ok)
                      .orElse(ResponseEntity.notFound().build());
    }

    @GetMapping("/search/city")
    public ResponseEntity<List<ParkingLocation>> searchByCity(@RequestParam String city) {
        List<ParkingLocation> locations = parkingLocationService.searchByCity(city);
        return ResponseEntity.ok(locations);
    }

    @GetMapping("/search/city-state")
    public ResponseEntity<List<ParkingLocation>> searchByCityAndState(@RequestParam String city,
                                                                     @RequestParam String state) {
        List<ParkingLocation> locations = parkingLocationService.searchByCityAndState(city, state);
        return ResponseEntity.ok(locations);
    }

    @GetMapping("/search/nearby")
    public ResponseEntity<List<ParkingLocation>> searchNearby(@RequestParam double latitude,
                                                             @RequestParam double longitude,
                                                             @RequestParam(defaultValue = "5.0") double radiusKm) {
        List<ParkingLocation> locations = parkingLocationService.searchNearbyLocations(latitude, longitude, radiusKm);
        return ResponseEntity.ok(locations);
    }

    @GetMapping("/search/available")
    public ResponseEntity<List<ParkingLocation>> getAvailableLocations() {
        List<ParkingLocation> locations = parkingLocationService.getAvailableLocations();
        return ResponseEntity.ok(locations);
    }

    @GetMapping("/search/name")
    public ResponseEntity<List<ParkingLocation>> searchByName(@RequestParam String name) {
        List<ParkingLocation> locations = parkingLocationService.searchByName(name);
        return ResponseEntity.ok(locations);
    }

    @GetMapping("/search")
    public ResponseEntity<List<ParkingLocation>> search(@RequestParam(required = false) String city,
                                                        @RequestParam(required = false) String locationName) {
        List<ParkingLocation> locations;

        if (city != null && locationName != null) {
            // Search by city and filter by name
            locations = parkingLocationService.searchByCity(city).stream()
                .filter(loc -> loc.getName().toLowerCase().contains(locationName.toLowerCase()))
                .collect(java.util.stream.Collectors.toList());
        } else if (city != null) {
            locations = parkingLocationService.searchByCity(city);
        } else if (locationName != null) {
            locations = parkingLocationService.searchByName(locationName);
        } else {
            locations = parkingLocationService.getAllLocations();
        }

        return ResponseEntity.ok(locations);
    }

    @GetMapping("/cities")
    public ResponseEntity<List<String>> getAllCities() {
        List<String> cities = parkingLocationService.getAllCities();
        return ResponseEntity.ok(cities);
    }

    @GetMapping("/location-names")
    public ResponseEntity<List<String>> getAllLocationNames() {
        List<String> names = parkingLocationService.getAllLocationNames();
        return ResponseEntity.ok(names);
    }

    @PostMapping("/locations")
    public ResponseEntity<ParkingLocation> createLocation(@RequestBody ParkingLocation location) {
        ParkingLocation savedLocation = parkingLocationService.saveLocation(location);
        return ResponseEntity.ok(savedLocation);
    }
}
