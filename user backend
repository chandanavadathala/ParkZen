package com.parking.parking.controller;

import com.parking.parking.entity.Booking;
import com.parking.parking.entity.ParkingLocation;
import com.parking.parking.repository.BookingRepository;
import com.parking.parking.service.ParkingLocationService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.Optional;

@RestController
@RequestMapping("/api/bookings")
public class BookingController {

    @Autowired
    private BookingRepository bookingRepository;

    @Autowired
    private ParkingLocationService parkingLocationService;

    @PostMapping("/book")
    public ResponseEntity<String> createBooking(@RequestParam Long userId, @RequestParam Long slotId, @RequestParam Long locationId, @RequestParam String startTime, @RequestParam String endTime) {
        try {
            Optional<ParkingLocation> locOpt = parkingLocationService.getLocationById(locationId);
            if (locOpt.isEmpty()) {
                return ResponseEntity.notFound().build();
            }
            ParkingLocation loc = locOpt.get();
            int avail = loc.getAvailableSlots();
            if (avail <= 0) {
                return ResponseEntity.badRequest().body("No available slots");
            }
            // Create booking
            LocalDateTime start = LocalDateTime.parse(startTime + ":00");
            LocalDateTime end = LocalDateTime.parse(endTime + ":00");
            Booking booking = new Booking(userId, slotId, locationId, start, end);
            bookingRepository.save(booking);
            // Decrement available slots
            loc.setAvailableSlots(avail - 1);
            parkingLocationService.save(loc);
            return ResponseEntity.ok("Booking confirmed for slot " + slotId + " at " + loc.getName());
        } catch (Exception e) {
            return ResponseEntity.badRequest().body("Error creating booking: " + e.getMessage());
        }
    }

    @GetMapping("/user/{userId}")
    public ResponseEntity<List<Map<String, Object>>> getUserBookings(@PathVariable Long userId) {
        List<Booking> bookings = bookingRepository.findByUserId(userId);
        List<Map<String, Object>> bookingData = new ArrayList<>();
        for (Booking booking : bookings) {
            Map<String, Object> map = new HashMap<>();
            map.put("id", booking.getId());
            map.put("userId", booking.getUserId());
            map.put("slotId", booking.getSlotId());
            map.put("locationId", booking.getLocationId());
            // Fetch location name
            Optional<ParkingLocation> locOpt = parkingLocationService.getLocationById(booking.getLocationId());
            String locationName = locOpt.map(ParkingLocation::getName).orElse("Unknown");
            map.put("locationName", locationName);
            map.put("startTime", booking.getStartTime());
            map.put("endTime", booking.getEndTime());
            map.put("status", booking.getStatus());
            bookingData.add(map);
        }
        return ResponseEntity.ok(bookingData);
    }

    @GetMapping("/slots/available/{locationId}")
    public ResponseEntity<List<Map<String, Object>>> getAvailableSlots(@PathVariable Long locationId) {
        Optional<ParkingLocation> locOpt = parkingLocationService.getLocationById(locationId);
        if (locOpt.isEmpty()) {
            return ResponseEntity.notFound().build();
        }
        ParkingLocation loc = locOpt.get();
        int avail = loc.getAvailableSlots();
        List<Map<String, Object>> slots = new ArrayList<>();
        for (int i = 1; i <= avail; i++) {
            Map<String, Object> slot = new HashMap<>();
            slot.put("id", i);
            slots.add(slot);
        }
        return ResponseEntity.ok(slots);
    }
}
